# Payroll system (Flask) — used on Replit, Render, and Vercel
PORT=5000
# Max upload size in MB (Vercel Hobby defaults to 4MB server-side)
MAX_UPLOAD_MB=50

# API server (Express) — only needed if you deploy api-server separately
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Mockup sandbox (Vite) — set when building or running locally
# BASE_PATH=/__mockup/
# PORT=8081

# Replit-only (ignored on Vercel)
# REPL_ID=
