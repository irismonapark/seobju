{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "api/payroll.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/healthz.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/api/payroll"
    }
  ]
}
